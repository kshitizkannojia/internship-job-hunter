# ── Database (Supabase PostgreSQL) ──────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Anthropic (Claude API) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Apollo.io (company/contact scraping) ───────────────────
APOLLO_API_KEY=

# ── Hunter.io (email verification) ─────────────────────────
HUNTER_API_KEY=

# ── Gmail OAuth2 ───────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/auth/gmail/callback
GMAIL_REFRESH_TOKEN=

# ── Redis (BullMQ job queue — Upstash free tier) ───────────
REDIS_URL=redis://default:...@...-redis.upstash.io:6379

# ── Tracking pixel base URL ───────────────────────────────
TRACKING_BASE_URL=http://localhost:3001/api/track
