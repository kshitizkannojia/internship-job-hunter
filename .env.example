# ── Database (Supabase PostgreSQL) ───────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Server ───────────────────────────────────
PORT=8000
ENV=development

# ── AI (Groq free tier — primary) ───────────
GROQ_API_KEY=

# ── AI fallbacks (optional) ─────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Scraping ─────────────────────────────────
APOLLO_API_KEY=

# ── Email Verification ──────────────────────
ZEROBOUNCE_API_KEY=

# ── Gmail OAuth2 ────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# ── Tracking ────────────────────────────────
TRACKING_BASE_URL=http://localhost:8000/track
